{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=86400, stale-if-error=86400"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=86400, stale-if-error=86400"
        }
      ]
    },
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    },
    {
      "source": "/build-info.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=86400, stale-if-error=86400"
        }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "caches": [
    {
      "source": "/",
      "cacheTtl": 1800
    },
    {
      "source": "/index.html",
      "cacheTtl": 1800
    },
    {
      "source": "/assets/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/build-info.json",
      "cacheTtl": 1800
    },
    {
      "source": "/config.js",
      "cacheTtl": 300
    },
    {
      "source": "/app.js",
      "cacheTtl": 300
    },
    {
      "source": "/styles.css",
      "cacheTtl": 300
    }
  ]
}
